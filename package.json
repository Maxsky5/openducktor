{
  "name": "openducktor",
  "private": true,
  "version": "0.2.6",
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter @openducktor/desktop dev",
    "browser:dev": "FORCE_COLOR=1 bun packages/openducktor-web/src/cli.ts --workspace",
    "hooks:install": "husky",
    "prepare": "bun run hooks:install",
    "release:version:set": "bun run scripts/release-version.ts set",
    "release:version:check": "bun run scripts/release-version.ts check",
    "release:homebrew:cask": "bun run scripts/release-homebrew-cask.ts",
    "test:release:homebrew:cask": "bun test scripts/release-homebrew-cask.test.ts",
    "release:cef:env": "bun run --cwd apps/desktop scripts/resolve-cef-release-env.ts",
    "tauri": "cd apps/desktop && bun run tauri",
    "tauri:dev": "cd apps/desktop && bun run tauri:dev",
    "tauri:build": "cd apps/desktop && bun run tauri:build",
    "tauri:setup:cef": "cd apps/desktop && bun run tauri:setup:cef",
    "tauri:dev:cef": "cd apps/desktop && FORCE_COLOR=1 bun run tauri:dev:cef",
    "tauri:build:cef": "cd apps/desktop && bun run tauri:build:cef",
    "check:rust": "cd apps/desktop/src-tauri && cargo check",
    "test:rust": "cd apps/desktop/src-tauri && cargo test",
    "web-host:build": "cd apps/desktop/src-tauri && cargo build --release --bin openducktor-web-host",
    "build": "bun run --workspaces build",
    "typecheck": "bun run --workspaces typecheck",
    "test": "bun run --workspaces test",
    "test:hooks": "bun run --filter @openducktor/desktop test:hooks",
    "lint": "bun run tauri:commands:panic-guard && bun run frontend:boundary-guard && bun run --workspaces lint",
    "frontend:boundary-guard": "bun run scripts/frontend-boundary-guard.ts",
    "tauri:commands:panic-guard": "bun run scripts/tauri-command-panic-guard.ts",
    "deps:unused:deps": "bunx knip --workspace='@openducktor/*' --include dependencies",
    "deps:unused:exports": "bunx knip --workspace='@openducktor/*' --include exports --no-exit-code",
    "deps:unused": "bun run deps:unused:deps && bun run deps:unused:exports",
    "deps:audit:high": "bun run scripts/audit-high-severity-guard.ts",
    "deps:audit:hono": "bun run scripts/audit-hono-guard.ts",
    "deps:outdated": "bun outdated",
    "deps:check": "bun run deps:audit:high && bun run deps:audit:hono && bun run deps:unused:deps"
  },
  "overrides": {
    "@hono/node-server": "^1.19.11",
    "express-rate-limit": "^8.2.2",
    "hono": "^4.12.7",
    "path-to-regexp": "^8.4.0",
    "rollup": "^4.59.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.0.0",
    "@biomejs/biome": "^2.4.13",
    "@iarna/toml": "^2.2.5",
    "@types/node": "^25.6.0",
    "husky": "^9.1.7",
    "knip": "^6.7.0",
    "typescript": "^6.0.3"
  }
}

{
  "name": "openducktor",
  "private": true,
  "version": "0.5.3",
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run electron:dev",
    "electron:dev": "cd apps/electron && bun run dev",
    "electron:build": "bun run --filter @openducktor/electron build",
    "electron:package": "bun run --filter @openducktor/electron package",
    "browser:dev": "cd packages/openducktor-web && bun run dev",
    "hooks:install": "husky",
    "prepare": "bun run hooks:install",
    "release:version:set": "bun run scripts/release-version.ts set",
    "release:version:check": "bun run scripts/release-version.ts check",
    "release:homebrew:cask": "bun run scripts/release-homebrew-cask.ts",
    "test:release:homebrew:cask": "bun test scripts/release-homebrew-cask.test.ts",
    "test:scripts": "bun test scripts/release-version.test.ts scripts/release-homebrew-cask.test.ts",
    "build": "bun run --workspaces build",
    "typecheck": "bun run --workspaces typecheck",
    "test": "bun run --workspaces test && bun run test:scripts",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "bun run frontend:boundary-guard && bun run host:architecture-guard && bun run --workspaces lint",
    "frontend:boundary-guard": "bun run scripts/frontend-boundary-guard.ts",
    "host:architecture-guard": "bun run scripts/host-architecture-guard.ts",
    "deps:unused:deps": "bunx knip --workspace='@openducktor/*' --include dependencies",
    "deps:unused:exports": "bunx knip --workspace='@openducktor/*' --include exports",
    "deps:unused:exports:report": "bunx knip --workspace='@openducktor/*' --include exports --no-exit-code",
    "deps:unused": "bun run deps:unused:deps && bun run deps:unused:exports",
    "deps:audit:high": "bun run scripts/audit-high-severity-guard.ts",
    "deps:audit:hono": "bun run scripts/audit-hono-guard.ts",
    "deps:outdated": "bun outdated",
    "deps:check": "bun run deps:audit:high && bun run deps:audit:hono && bun run deps:unused:deps && bun run deps:unused:exports",
    "react-doctor:full": "npx -y react-doctor@latest . --full",
    "react-doctor:diff": "npx -y react-doctor@latest . --diff main --yes"
  },
  "overrides": {
    "@hono/node-server": "^1.19.11",
    "express-rate-limit": "^8.2.2",
    "fast-uri": "^3.1.3",
    "form-data": "^4.0.6",
    "hono": "^4.12.26",
    "path-to-regexp": "^8.4.0",
    "rollup": "^4.59.0",
    "tmp": "^0.2.7",
    "undici": "^7.28.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@biomejs/biome": "^2.5.4",
    "@types/node": "^26.1.1",
    "husky": "^9.1.7",
    "knip": "^6.27.0",
    "typescript": "^5.7.3",
    "yaml": "^2.9.0"
  }
}

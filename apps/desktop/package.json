{
  "name": "@openducktor/desktop",
  "version": "0.2.4",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "tauri": "tauri",
    "tauri:dev": "tauri dev -- --bin openducktor-desktop",
    "tauri:build": "bun run scripts/tauri-build.ts",
    "tauri:setup:cef": "bun run scripts/setup-cef.ts",
    "tauri:dev:cef": "FORCE_COLOR=1 bun run scripts/tauri-cef-dev.ts",
    "tauri:build:cef": "bun run scripts/tauri-cef-build.ts",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "bunx tsc -p tsconfig.json --noEmit",
    "test:hooks": "bun test ./scripts/git-hooks.integration.test.ts --timeout 120000",
    "test": "bun test --pass-with-no-tests --timeout 1000",
    "lint": "biome check src scripts"
  },
  "dependencies": {
    "@openducktor/adapters-tauri-host": "workspace:*",
    "@openducktor/frontend": "workspace:*",
    "@tauri-apps/api": "^2.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-react": "^6.0.1",
    "bun-types": "^1.3.12",
    "vite": "^8.0.9"
  }
}

{
  "name": "@openducktor/electron",
  "productName": "OpenDucktor",
  "version": "0.5.3",
  "description": "OpenDucktor desktop application",
  "homepage": "https://github.com/Maxsky5/openducktor",
  "author": {
    "name": "Maxsky5",
    "email": "maxsky5@users.noreply.github.com"
  },
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "bun run scripts/build.ts",
    "build:main": "bun build --target=node --external electron --external node-pty --splitting --outdir dist --entry-naming 'main.[ext]' --chunk-naming 'chunks/[name]-[hash].[ext]' src/main/main.ts",
    "build:preload": "bun build --target=node --format=cjs --external electron --outfile dist/preload.cjs src/preload/preload.ts",
    "build:renderer": "vite build --outDir dist/renderer --emptyOutDir",
    "builder": "electron-builder",
    "dev": "bun run scripts/dev.ts",
    "dev:electron": "bun run scripts/dev.ts",
    "dev:renderer": "vite --host 127.0.0.1 --port 1430 --strictPort",
    "package": "bun run scripts/package-build.ts",
    "release:artifact": "bun run scripts/package-build.ts --stage-release-artifacts",
    "preview": "electron dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun test --pass-with-no-tests --timeout 1000",
    "lint": "biome check src scripts vite.config.ts"
  },
  "devDependencies": {
    "@openducktor/build-tools": "workspace:*",
    "@openducktor/contracts": "workspace:*",
    "@openducktor/frontend": "workspace:*",
    "@openducktor/host": "workspace:*",
    "@openducktor/host-client": "workspace:*",
    "@tailwindcss/vite": "^4.3.3",
    "@types/node": "^26.1.1",
    "@types/semver": "^7.7.1",
    "@vitejs/plugin-react": "^6.0.3",
    "bun-types": "^1.3.14",
    "effect": "^3.22.0",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "vite": "^8.1.5",
    "zod": "^4.4.3"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "node-pty": "1.2.0-beta.14",
    "semver": "7.8.5",
    "yaml": "^2.9.0"
  }
}

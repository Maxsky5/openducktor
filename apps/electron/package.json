{
  "name": "@openducktor/electron",
  "productName": "OpenDucktor",
  "version": "0.3.1",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "rm -rf dist && bun run build:main && bun run build:preload && bun run build:renderer",
    "build:main": "bun build --target=node --external electron --outfile dist/main.js src/main/main.ts",
    "build:preload": "bun build --target=node --format=cjs --external electron --outfile dist/preload.cjs src/preload/preload.ts",
    "build:renderer": "vite build --outDir dist/renderer --emptyOutDir",
    "dev": "bun run scripts/dev.ts",
    "dev:electron": "bun run scripts/dev.ts",
    "dev:renderer": "vite --host 127.0.0.1 --port 1430 --strictPort",
    "prepare:sidecars": "bun run scripts/prepare-mcp-sidecar.ts",
    "package": "bun run prepare:sidecars && bun run build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --config electron-builder.yml --publish never",
    "preview": "electron dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun test --pass-with-no-tests --timeout 1000",
    "lint": "biome check src scripts vite.config.ts"
  },
  "dependencies": {
    "@openducktor/adapters-tauri-host": "workspace:*",
    "@openducktor/frontend": "workspace:*",
    "@openducktor/host": "workspace:*",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-react": "^6.0.1",
    "bun-types": "^1.3.13",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "vite": "^8.0.10"
  }
}

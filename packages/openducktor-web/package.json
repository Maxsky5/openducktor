{
  "name": "@openducktor/web",
  "version": "0.5.3",
  "type": "module",
  "main": "./dist/cli.js",
  "exports": {
    ".": "./dist/cli.js"
  },
  "bin": {
    "web": "dist/cli.js",
    "openducktor-web": "dist/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Maxsky5/openducktor.git"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "start": "bun run src/cli.ts",
    "build": "bun run scripts/build.ts",
    "build:web-shell": "bunx vite build --outDir dist/web-shell --emptyOutDir",
    "build:cli": "bun run scripts/build-cli.ts",
    "build:mcp": "bun run scripts/build-mcp.ts",
    "typecheck": "bunx tsc -p tsconfig.json --noEmit",
    "test": "bun test --timeout 1000",
    "lint": "biome check src scripts",
    "publish:dry-run": "npm publish --dry-run --access public"
  },
  "devDependencies": {
    "@openducktor/build-tools": "workspace:*",
    "@openducktor/contracts": "workspace:*",
    "@openducktor/host-client": "workspace:*",
    "@openducktor/frontend": "workspace:*",
    "@openducktor/host": "workspace:*",
    "effect": "^3.22.0",
    "@tailwindcss/vite": "^4.3.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@types/node": "^26.1.1",
    "@types/ws": "^8.18.1",
    "bun-types": "^1.3.14",
    "vite": "^8.1.5",
    "ws": "^8.21.1"
  }
}

{
  "name": "@openducktor/web",
  "version": "0.3.1",
  "type": "module",
  "main": "./dist/cli.js",
  "exports": {
    ".": "./dist/cli.js"
  },
  "bin": {
    "web": "dist/cli.js",
    "openducktor-web": "dist/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Maxsky5/openducktor.git"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "bun run scripts/dev.ts --workspace",
    "start": "bun run src/cli.ts",
    "build": "bun run scripts/build.ts",
    "build:web-shell": "bunx vite build --outDir dist/web-shell --emptyOutDir",
    "build:cli": "bun run scripts/build-cli.ts",
    "typecheck": "bunx tsc -p tsconfig.json --noEmit",
    "test": "bun test --timeout 1000",
    "lint": "biome check src scripts",
    "publish:dry-run": "npm publish --dry-run --access public"
  },
  "devDependencies": {
    "@openducktor/adapters-tauri-host": "workspace:*",
    "@openducktor/frontend": "workspace:*",
    "@openducktor/host": "workspace:*",
    "@tailwindcss/vite": "^4.2.4",
    "@vitejs/plugin-react": "^6.0.1",
    "@types/node": "^25.6.0",
    "bun-types": "^1.3.13",
    "vite": "^8.0.10"
  }
}

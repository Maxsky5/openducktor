{
  "name": "@openducktor/web",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/cli.js",
  "types": "./dist/cli.d.ts",
  "exports": {
    ".": {
      "types": "./dist/cli.d.ts",
      "default": "./dist/cli.js"
    }
  },
  "bin": {
    "web": "dist/cli.js",
    "openducktor-web": "dist/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Maxsky5/openducktor.git"
  },
  "files": [
    "bin",
    "dist",
    "index.html",
    "README.md",
    "src",
    "vite.config.ts"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "bun run src/cli.ts --workspace",
    "start": "bun run src/cli.ts",
    "build": "bun build --target=bun --packages external --outfile dist/cli.js --banner '#!/usr/bin/env bun' src/cli.ts && chmod +x dist/cli.js && bunx tsc -p tsconfig.json --declaration --emitDeclarationOnly --noEmit false --outDir dist",
    "typecheck": "bunx tsc -p tsconfig.json --noEmit",
    "test": "bun test --timeout 1000",
    "lint": "biome check src"
  },
  "dependencies": {
    "@openducktor/adapters-tauri-host": "workspace:*",
    "@openducktor/frontend": "workspace:*",
    "@tailwindcss/vite": "^4.2.2",
    "@vitejs/plugin-react": "^6.0.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "vite": "^8.0.9"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.1",
    "bun-types": "^1.3.12"
  }
}

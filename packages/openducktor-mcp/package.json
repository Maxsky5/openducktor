{
  "name": "@openducktor/mcp",
  "version": "0.4.3",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "openducktor-mcp": "dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Maxsky5/openducktor.git"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "build": "bun run scripts/build.ts",
    "typecheck": "bunx tsc -p tsconfig.json --noEmit && bunx tsc -p tsconfig.scripts.json --noEmit",
    "test": "bun test --timeout 1000 --max-concurrency=1",
    "lint": "biome check src scripts",
    "publish:dry-run": "bun publish --dry-run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@openducktor/build-tools": "workspace:*",
    "@openducktor/contracts": "workspace:*",
    "@openducktor/path-support": "workspace:*",
    "bun-types": "^1.3.14"
  }
}

  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "bunx tsc -p tsconfig.build.json",
    "db:generate": "drizzle-kit generate --config drizzle.task-store.config.ts",

    "@openducktor/path-support": "workspace:*",
    "drizzle-orm": "0.45.2",
    "effect": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "bun-types": "^1.3.14",
    "drizzle-kit": "0.31.10"
  }
